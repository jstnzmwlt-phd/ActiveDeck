<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  ActiveDeck PowerPoint Content Add-in Manifest
  ==============================================
  This file registers ActiveDeck as a CONTENT ADD-IN inside PowerPoint.
  Unlike a sidebar taskpane, Content Add-ins are embedded directly on a slide
  and remain fully visible and interactive during full-screen Slide Show presentations.

  To use this manifest:
  1. Open PowerPoint Web (office.com) or PowerPoint Desktop.
  2. Go to Insert -> Add-ins -> Upload My Add-in.
  3. Select this "activedeck-powerpoint-content-manifest.xml" file.
  4. Once uploaded, go to Insert -> Add-ins -> Select "ActiveDeck Slide Widget" 
     to insert the interactive chat directly onto your desired slide.
-->
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xsi:type="ContentApp"
>
  <!-- Basic Identification (Unique GUID distinct from the Task Pane version) -->
  <Id>b29e64d5-450f-48d9-a785-5a2bb43df12f</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>ActiveDeck</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  
  <!-- Display Name & Description -->
  <DisplayName DefaultValue="ActiveDeck Slide Widget" />
  <Description DefaultValue="Embedded interactive presentation dashboard, Q&amp;A stream, and live word cloud directly inside your PowerPoint slides. Stays visible and interactive in full-screen Slide Show." />
  
  <!-- Icon Assets -->
  <IconUrl DefaultValue="https://active-deck.app/assets/logo-32.png" />
  <HighResolutionIconUrl DefaultValue="https://active-deck.app/assets/logo-80.png" />
  <SupportUrl DefaultValue="https://active-deck.app/support" />
  
  <!-- Target Host -->
  <Hosts>
    <Host Name="Presentation" /> <!-- PowerPoint -->
  </Hosts>
  
  <!-- Content Add-in Dimensions and Target URL -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://active-deck.app/" />
    <RequestedWidth>480</RequestedWidth>
    <RequestedHeight>640</RequestedHeight>
  </DefaultSettings>
  
  <!-- Permissions -->
  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
