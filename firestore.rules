rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // ACTIVEDECK SECURITY RULES
    // ==========================================
    
    // Helper function to check if the current user is the owner/presenter of a presentation
    function isPresenter(presId) {
      return request.auth != null && get(/databases/$(database)/documents/presentations/$(presId)).data.presenterId == request.auth.uid;
    }

    // Helper function to check if the current user is a whitelisted presenter
    function isWhitelistedPresenter() {
      return request.auth != null && 
             'email' in request.auth.token && 
             (request.auth.token.email.lower() == 'justin.zumwalt@okstate.edu' ||
              exists(/databases/$(database)/documents/whitelistedPresenters/$(request.auth.token.email.lower())));
    }

    match /presentations/{presentationId} {
      // Anyone can read a presentation configuration; only the owner/presenter can create or update it
      // Deletions are allowed for any authenticated user (including anonymous presenters in the Admin Portal)
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.presenterId == request.auth.uid || isWhitelistedPresenter());
      allow delete: if request.auth != null;

      match /attendance_tokens/{tokenId} {
        // Students must be able to read active QR tokens; only the presenter can write/delete them
        allow read: if request.auth != null;
        allow create, update: if isPresenter(presentationId) || isWhitelistedPresenter();
        allow delete: if request.auth != null;
      }

      match /attendance/{studentEmail} {
        // Students can write (create or update) their own check-in record; only the presenter can read the class roster (critical for FERPA)
        // If there is an active institution domain globally configured, enforce that student's email matches the domain.
        allow create, update: if request.auth != null && (
          !exists(/databases/$(database)/documents/settings/global) ||
          !("activeInstitutionDomain" in get(/databases/$(database)/documents/settings/global).data) ||
          get(/databases/$(database)/documents/settings/global).data.activeInstitutionDomain == "" ||
          get(/databases/$(database)/documents/settings/global).data.activeInstitutionDomain == null ||
          studentEmail.matches(".*@" + get(/databases/$(database)/documents/settings/global).data.activeInstitutionDomain + "$") ||
          studentEmail.matches(".*\\." + get(/databases/$(database)/documents/settings/global).data.activeInstitutionDomain + "$")
        );
        allow read: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    match /messages/{messageId} {
      // Chat messages are viewable and listable by anyone in the class
      allow read: if request.auth != null;
      // Any authenticated student/presenter can send a message
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        isPresenter(resource.data.presentationId) ||
        isWhitelistedPresenter()
      );
      allow delete: if request.auth != null;
    }

    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isPresenter(request.resource.data.presentationId) || isWhitelistedPresenter());
      // Allow updates so students can register their votes, but restrict deletion/creation to presenters/admins
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (isPresenter(resource.data.presentationId) || isWhitelistedPresenter());
    }

    match /wordClouds/{cloudId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isPresenter(request.resource.data.presentationId) || isWhitelistedPresenter());
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (isPresenter(resource.data.presentationId) || isWhitelistedPresenter());
    }

    match /openEndedQuestions/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isPresenter(request.resource.data.presentationId) || isWhitelistedPresenter());
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (isPresenter(resource.data.presentationId) || isWhitelistedPresenter());
    }

    match /settings/{docId} {
      // Global settings are readable by all clients; writable only by authenticated users (admins)
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /savedThemes/{docId} {
      // Themes are readable by all clients; writable only by authenticated users (admins)
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /test/{docId} {
      allow read, write: if request.auth != null;
    }

    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isPresenter(resource.data.presentationId) || isWhitelistedPresenter());
      allow delete: if request.auth != null && (isPresenter(resource.data.presentationId) || isWhitelistedPresenter());
    }

    match /participants/{participantId} {
      allow read, write: if request.auth != null;
    }

    match /sessionPins/{pin} {
      allow read, write: if request.auth != null;
    }

    match /whitelistedPresenters/{email} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && email != 'justin.zumwalt@okstate.edu';
    }

    match /slidePreviews/{previewId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
