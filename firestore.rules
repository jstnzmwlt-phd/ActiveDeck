rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // ACTIVEDECK SECURITY RULES
    // ==========================================
    match /presentations/{presentationId} {
      allow read, write: if true;

      match /attendance_tokens/{tokenId} {
        allow read, write: if true;
      }

      match /attendance/{studentEmail} {
        allow create: if request.resource.data.checkedInAt == request.time
                      && get(/databases/$(database)/documents/presentations/$(presentationId)/attendance_tokens/$(request.resource.data.scannedToken)).data.createdAt >= request.time - duration.value(45, "s");
        allow read, update, delete: if true;
      }
    }

    match /messages/{messageId} {
      allow read, write: if true;
    }

    match /polls/{pollId} {
      allow read, write: if true;
    }

    match /wordClouds/{cloudId} {
      allow read, write: if true;
    }

    match /openEndedQuestions/{questionId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, write: if true;
    }

    match /savedThemes/{docId} {
      allow read, write: if true;
    }

    match /test/{docId} {
      allow read, write: if true;
    }

    match /questions/{questionId} {
      allow read, write: if true;
    }

    match /participants/{participantId} {
      allow read, write: if true;
    }
  }
}
