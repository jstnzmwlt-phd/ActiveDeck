# .env.example
# This file documents the environment variables required for the project.
# Copy this file to .env and fill in the values for local development.
# NEVER commit actual secrets to this file or to version control.

# Gemini API Key (Required for AI features)
GEMINI_API_KEY=

# Stripe API Keys (Optional - for payments/subscriptions)
# VITE_ prefix is required for client-side access in Vite
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# OpenAI API Key (Optional - alternative AI features)
OPENAI_API_KEY=

# Firebase Configuration (Managed via firebase-applet-config.json in this environment)
# These are typically not needed in .env for this specific platform setup.
