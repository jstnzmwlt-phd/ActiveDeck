{
  "entities": {
    "Presentation": {
      "title": "Presentation",
      "description": "A presentation document with an embed URL.",
      "type": "object",
      "properties": {
        "embedUrl": {
          "type": "string",
          "description": "The Microsoft Office Web Viewer URL."
        },
        "presenterId": {
          "type": "string",
          "description": "The UID of the presenter."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the presentation was created."
        },
        "allowAnonymousChat": {
          "type": "boolean",
          "description": "Whether anonymous chat is allowed."
        }
      },
      "required": ["embedUrl", "presenterId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message from the audience.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the message."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the sender."
        },
        "userName": {
          "type": "string",
          "description": "The name of the sender."
        },
        "userEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the sender, if provided."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The time the message was sent."
        },
        "isQuestion": {
          "type": "boolean",
          "description": "Whether the message is a question."
        },
        "presentationId": {
          "type": "string",
          "description": "The ID of the presentation this message belongs to."
        },
        "presenterId": {
          "type": "string",
          "description": "The UID of the presenter who can moderate this message."
        },
        "likes": {
          "type": "number",
          "description": "The number of likes this message has received."
        },
        "likedBy": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "The UIDs of the users who have liked this message."
        }
      },
      "required": ["text", "userId", "userName", "timestamp", "isQuestion", "presentationId", "presenterId"]
    },
    "Poll": {
      "title": "Poll",
      "description": "A multiple choice poll for the audience.",
      "type": "object",
      "properties": {
        "presentationId": {
          "type": "string",
          "description": "The ID of the presentation."
        },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The list of options (e.g., A, B, C, D, E)."
        },
        "votes": {
          "type": "object",
          "description": "A map of option to vote count."
        },
        "voters": {
          "type": "object",
          "description": "A map of userId to selected option."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the poll was created."
        },
        "active": {
          "type": "boolean",
          "description": "Whether the poll is currently active."
        }
      },
      "required": ["presentationId", "options", "votes", "voters", "createdAt", "active"]
    }
  },
  "firestore": {
    "/presentations/{presentationId}": {
      "schema": "Presentation",
      "description": "Collection of presentations."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of chat messages."
    },
    "/polls/{pollId}": {
      "schema": "Poll",
      "description": "Collection of polls."
    }
  }
}
